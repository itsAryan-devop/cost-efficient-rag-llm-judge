# Copy to .env and fill in your keys. .env is gitignored; never commit it.

# --- API keys ---
GEMINI_API_KEY=your_gemini_api_key_here
# Optional comma-separated rotation pool. GEMINI_API_KEY is also included automatically.
GEMINI_API_KEYS=your_first_key_here,your_second_key_here
GROQ_API_KEY=your_groq_api_key_here

# --- Providers: gemini, groq, mock ---
# Recommended free/low-cost config. The judge family is kept different from the
# generator family so the judge does not grade its own model's output.
EMBEDDING_PROVIDER=gemini
GENERATION_PROVIDER=groq
JUDGE_PROVIDER=gemini

# --- Models ---
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIMENSION=768
GENERATION_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile
# Optional. Leave blank to reuse the provider default model above.
JUDGE_MODEL=
GEMINI_MAX_RETRIES=2

# --- Chunking: CHUNK_SIZE and CHUNK_OVERLAP are CHARACTERS (RecursiveCharacterTextSplitter) ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5
# LanceDB distance cutoff, calibrated for the real embedding model. Lower is more
# similar; a nearest-chunk distance above this skips the LLM (no-context refusal).
MAX_RETRIEVAL_DISTANCE=0.90

# --- Paths ---
DATA_ROOT=data/corpus
DB_PATH=db/lancedb
CACHE_PATH=cache/diskcache
REPORTS_PATH=reports

# ====================================================================
# Problem 2 — LLM-as-Judge Pipeline Config
# ====================================================================
# The pipeline keeps judge and generator independently configurable.
# Self-enhancement bias is flagged when both use the same provider.
#
# JUDGE_PROVIDER and JUDGE_MODEL control which LLM evaluates outputs.
# GENERATOR_PROVIDER and GENERATOR_MODEL describe what produced them.
# OPENAI_API_KEY or OPENROUTER_API_KEY enable OpenAI/OpenRouter judges.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GENERATOR_PROVIDER=groq
GENERATOR_MODEL=llama-3.3-70b-versatile
MAX_JUDGE_RETRIES=2
JUDGE_TEMPERATURE=0.0
AUDIT_LOG_PATH=reports/p2_audit_log.jsonl
REPORT_PATH=reports/p2_evaluation_report.json
CSV_REPORT_PATH=reports/p2_results.csv
